# MuralPicta WallPanel Server – Umgebungsvariablen
# Kopiere diese Datei zu .env und passe die Werte an:
#   cp .env.example .env

# Port, auf dem der Server erreichbar ist (Standard: 3000)
PORT=3000

# Pfad zum Medienordner auf dem Host.
# Dieser Ordner wird als /data/media in den Container gemountet (read-only).
#
# Beispiele:
#   Synology:   MEDIA_PATH=/volume1/medien
#   QNAP:       MEDIA_PATH=/share/multimedia
#   Linux:      MEDIA_PATH=/home/user/photos
#   Windows:    MEDIA_PATH=C:/Users/User/Pictures
#
# Für mehrere Ordner: Einträge direkt in docker-compose.yml anpassen.
MEDIA_PATH=/path/to/your/media
